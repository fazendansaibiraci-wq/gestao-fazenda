generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  FUNCIONARIO
  GERENTE
  AGRONOMO
  GESTOR
}

enum TipoSalario {
  MENSAL
  DIARIO
}

enum TalhaoStatus {
  ATIVO
  INATIVO
  PREPARACAO
  COLHEITA
}

enum PerfilTalhao {
  RECEM_PLANTADO
  ESQUELETADO
  PLENA_PRODUCAO
}

enum MaquinaStatus {
  ATIVA
  MANUTENCAO
  INATIVA
}

enum SafraStatus {
  ATIVA
  ENCERRADA
}

enum TipoAtividade {
  PULVERIZACAO
  HERBICIDA
  ADUBACAO
  COLHEITA
  CAPINA_MECANICA
  DESBROTA
  CAPINA_MANUAL
  CHEGAMENTO_TERRA
  CORRECAO_SOLO
  IRRIGACAO
  INSETICIDA_SOLO
  GERAIS
}

enum StatusRegistroAtividade {
  EM_ANDAMENTO
  CONCLUIDO
  PENDENTE
}

// Models
model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  name     String
  role     UserRole @default(FUNCIONARIO)
  phone    String?
  active   Boolean  @default(true)

  // Campos de funcionário
  tipoSalario               TipoSalario?
  salarioEntressafra        Float?
  salarioSafra              Float?
  valorHoraExtraEntressafra Float?
  valorHoraExtraSafra       Float?
  bancoHorasAtivo           Boolean      @default(false)

  // Relacionamentos
  escalasEntressafra  EscalaEntressafra[]
  escalasAfra         EscalaSafra[]
  registrosAtividade  RegistroAtividade[]
  bancoHoras          BancoHoras?
  aprovacoesPendentes AprovacaoHoraExtra[]

  // M2 - Combustível
  conferenciasEstoque ConferenciaEstoque[]

  // M3 - Receitas
  receitasCriadas  ReceitaBase[]     @relation("ReceitaBaseCriador")
  ajustesReceita   AjusteReceita[]
  aplicacoesInsumo AplicacaoInsumo[]

  // M4 - Rastreabilidade (Etapas)
  etapasTerreiro      EtapaTerreiro[]
  etapasSecador       EtapaSecador[]
  etapasTulha         EtapaTulha[]
  etapasBeneficio     EtapaBeneficio[]
  etapasClassificacao EtapaClassificacao[]
  etapasSilo          EtapaSilo[]
  etapasArmazem       EtapaArmazem[]

  // M5 - Vales
  valesRecebidos Vale[] @relation("ValesRecebidos")
  valesLancados  Vale[] @relation("ValesLancados")

  // M7 - Assistente
  chatSessions  AssistantChat[]
  assistantLogs AssistantLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Escalas de trabalho
model EscalaEntressafra {
  id                    String  @id @default(cuid())
  funcionario           User    @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  funcionarioId         String
  diaSemana             Int // 0-6 (domingo a sábado)
  horarioEntrada        String // HH:MM
  horarioSaida          String // HH:MM
  intervaloAlmocoInicio String? // HH:MM
  intervaloAlmocoFim    String? // HH:MM

  @@unique([funcionarioId, diaSemana])
  @@map("escalas_entressafra")
}

model EscalaSafra {
  id                    String   @id @default(cuid())
  funcionario           User     @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  funcionarioId         String
  data                  DateTime // data específica
  horarioEntrada        String // HH:MM
  horarioSaida          String // HH:MM
  intervaloAlmocoInicio String?
  intervaloAlmocoFim    String?
  ehFeriado             Boolean  @default(false)

  @@unique([funcionarioId, data])
  @@map("escalas_safra")
}

// Banco de horas
model BancoHoras {
  id               String @id @default(cuid())
  funcionario      User   @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  funcionarioId    String @unique
  saldoHoras       Float  @default(0)
  mes              Int // 1-12
  ano              Int
  saldoAnterior    Float  @default(0)
  horasAdicionadas Float  @default(0)
  horasAbatidas    Float  @default(0)

  ultimaAtualizacao DateTime @updatedAt

  @@unique([funcionarioId, mes, ano])
  @@map("banco_horas")
}

// Aprovações de hora extra
model AprovacaoHoraExtra {
  id            String  @id @default(cuid())
  funcionario   User    @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  funcionarioId String
  registroId    String
  horasExtras   Float
  status        String  @default("pendente") // pendente, aprovado, rejeitado
  observacao    String?

  criadoEm   DateTime  @default(now())
  aprovadoEm DateTime?

  @@map("aprovacoes_hora_extra")
}

model Talhao {
  id                String       @id @default(cuid())
  nome              String
  area              Float // hectares
  fazenda           String?
  cultura           String?
  status            TalhaoStatus @default(ATIVO)
  dataCriacao       DateTime     @default(now())
  ultimaAtualizacao DateTime     @updatedAt

  talfaoSafra        TalhaoSafra[]
  registrosAtividade RegistroAtividade[]
  chegadasTerreiro   ChegadaTerreiro[]

  // M3 - Receitas
  aplicacoesInsumo   AplicacaoInsumo[]
  historicoAplicacao HistoricoAplicacao[]

  @@map("talhoes")
}

// Perfil de talhão por safra
model TalhaoSafra {
  id       String       @id @default(cuid())
  talhao   Talhao       @relation(fields: [talhaoId], references: [id], onDelete: Cascade)
  talhaoId String
  safra    Safra        @relation(fields: [safraId], references: [id], onDelete: Cascade)
  safraId  String
  perfil   PerfilTalhao

  @@unique([talhaoId, safraId])
  @@map("talhao_safra")
}

model Maquina {
  id                String        @id @default(cuid())
  nome              String
  tipo              String // Trator/Pulverizador/Colhedora/Implemento
  marca             String?
  modelo            String?
  ano               Int?
  placa             String?
  status            MaquinaStatus @default(ATIVA)
  ultimoHorimetro   Float         @default(0)
  dataCriacao       DateTime      @default(now())
  ultimaAtualizacao DateTime      @updatedAt

  registrosAtividade RegistroAtividade[]
  abastecimentos     AbastecimentoTrator[] @relation("AbastecimentoTrator")

  @@map("maquinas")
}

model Produto {
  id                String   @id @default(cuid())
  nomeComercial     String
  categoria         String // fertilizante/fungicida/herbicida/inseticida/adjuvante/corretivo
  unidadeMedida     String // L/kg/g/ml/sacas/bags
  valorUnitario     Float
  fornecedor        String?
  status            Boolean  @default(true) // ativo/inativo
  dataCriacao       DateTime @default(now())
  ultimaAtualizacao DateTime @updatedAt

  receitas Receita[]

  // Receitas de Aplicação
  produtosAplicacao ProdutoAplicacao[]

  // M3 - Receitas
  produtosReceita ProdutoReceita[] @relation("ProdutoReceitaBase")
  ajustes         AjusteReceita[]  @relation("AjusteReceitaProduto")

  @@map("produtos")
}

// Receitas de insumos por talhão/safra/perfil
model Receita {
  id           String       @id @default(cuid())
  produto      Produto      @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  produtoId    String
  safra        Safra        @relation(fields: [safraId], references: [id], onDelete: Cascade)
  safraId      String
  perfilTalhao PerfilTalhao
  dosagem      Float
  unidade      String // mesma unidade do produto
  tipo         String // tipo de atividade (pulverização, adubação, etc)

  @@unique([produtoId, safraId, perfilTalhao, tipo])
  @@map("receitas")
}

// Receitas de Aplicação - cadastradas pelo Gestor
model ReceitaAplicacao {
  id            String   @id @default(cuid())
  nome          String   @unique // ex: "Herbicida Pré-emergente"
  tipo          TipoAtividade // PULVERIZACAO, HERBICIDA, CORRETIVO_SOLO, ADUBACAO, INSETICIDA_SOLO
  observacoes   String?
  ativo         Boolean  @default(true)

  // Produtos utilizados e suas dosagens
  produtosAplicacao ProdutoAplicacao[]

  // Referência na atividade
  registrosAtividade RegistroAtividade[]

  dataCriacao       DateTime @default(now())
  ultimaAtualizacao DateTime @updatedAt

  @@map("receitas_aplicacao")
}

// Relação muitos-para-muitos: Receita tem muitos Produtos com dosagem
model ProdutoAplicacao {
  id              String   @id @default(cuid())
  receita         ReceitaAplicacao @relation(fields: [receitaId], references: [id], onDelete: Cascade)
  receitaId       String

  produto         Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  produtoId       String

  dosagem         Float    // quantidade
  unidade         String   // L, kg, g, ml, sacas, bags (mesma do produto)

  dataCriacao     DateTime @default(now())

  @@unique([receitaId, produtoId])
  @@map("produtos_aplicacao")
}

model Safra {
  id                String      @id @default(cuid())
  nome              String // ex: "Safra 25/26"
  dataInicio        DateTime
  dataFim           DateTime?
  status            SafraStatus @default(ATIVA)
  dataCriacao       DateTime    @default(now())
  ultimaAtualizacao DateTime    @updatedAt

  talhaoSafra        TalhaoSafra[]
  receitas           Receita[]
  registrosAtividade RegistroAtividade[]
  lotes              Lote[]
  chegadasTerreiro   ChegadaTerreiro[]

  // M3 - Receitas
  receitasBase ReceitaBase[]        @relation("ReceitaBaseSafra")
  aplicacoes   AplicacaoInsumo[]    @relation("AplicacaoInsumoSafra")
  historico    HistoricoAplicacao[] @relation("HistoricoAplicacaoSafra")

  // SafraReceita relation
  safraReceita  SafraReceita?  @relation("SafraReceitasRelacao")
  safraExtended SafraExtended?

  @@map("safras")
}

model RegistroAtividade {
  id                String   @id @default(cuid())
  funcionario       User     @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  funcionarioId     String
  data              DateTime
  horaEntrada       String // HH:MM
  horaSaida         String? // HH:MM
  horasCalculadas   Float? // calculado automaticamente
  horasprevistasdia Float?

  talhao   Talhao @relation(fields: [talhaoId], references: [id])
  talhaoId String

  safra   Safra  @relation(fields: [safraId], references: [id])
  safraId String

  tipoAtividade TipoAtividade
  status        StatusRegistroAtividade @default(PENDENTE)
  observacao    String?
  fotoEvidencia String? // URL da imagem

  // Receita de Aplicação
  receitaAplicacao   ReceitaAplicacao? @relation(fields: [receitaAplicacaoId], references: [id], onDelete: SetNull)
  receitaAplicacaoId String?

  // Campos condicionais por tipo de atividade
  totalBombas         Int? // Pulverização/Herbicida/Inseticida solo
  tipoAdubo           String? // Adubação
  quantidadeAdubo     Float? // Adubação (toneladas/kg)
  tipoCorretivo       String? // Correção de solo
  quantidadeCorretivo Float? // toneladas

  // Máquina e implemento
  maquina             Maquina? @relation(fields: [maquinaId], references: [id], onDelete: SetNull)
  maquinaId           String?
  horimetroInicial    Float?
  horimetroFinal      Float?
  horasMaquina        Float? // calculado: horimetroFinal - horimetroInicial
  implementoUtilizado String?

  // Falta
  isFalta         Boolean @default(false)
  motivoFalta     String? // atestado médico/pessoal/outro
  observacaoFalta String?

  // Hora extra
  ehHoraExtra     Boolean @default(false)
  statusAprovacao String  @default("pendente") // pendente, aprovado, rejeitado

  // AplicacaoInsumo relation
  aplicacoesInsumo AplicacaoInsumo[]

  dataCriacao       DateTime @default(now())
  ultimaAtualizacao DateTime @updatedAt

  @@index([funcionarioId])
  @@index([data])
  @@index([status])
  @@map("registros_atividade")
}

model Feriado {
  id          String   @id @default(cuid())
  data        DateTime @unique
  nome        String
  descricao   String?
  tipo        String   @default("nacional") // nacional/municipal
  dataCriacao DateTime @default(now())

  @@map("feriados")
}

// ========== M2 - COMBUSTÍVEL E DIESEL ==========

model AbastecimentoTrator {
  id                String   @id @default(cuid())
  data              DateTime
  maquina           Maquina  @relation("AbastecimentoTrator", fields: [maquinaId], references: [id])
  maquinaId         String
  horimetroAtual    Float
  horimetroanterior Float?
  litrosAbastecidos Float
  valorPorLitro     Float // R$/litro

  // Cálculos automáticos
  horasTrabalhadad   Float? // horímetro atual - anterior
  consumoLporH       Float? // litros / horas trabalhadas
  custoAbastecimento Float? // litros × R$/litro
  consumoMedio       Float? // histórico do trator
  alertaConsumo      Boolean @default(false)

  observacao        String?
  dataCriacao       DateTime @default(now())
  ultimaAtualizacao DateTime @updatedAt

  @@index([maquinaId, data])
  @@map("abastecimentos_trator")
}

model EntradaDiesel {
  id              String   @id @default(cuid())
  data            DateTime
  litrosRecebidos Float
  valorPorLitro   Float // R$/litro
  custoTotal      Float? // litros × R$/litro
  nf              String? // número nota fiscal
  fornecedor      String?

  observacao  String?
  dataCriacao DateTime @default(now())

  @@index([data])
  @@map("entradas_diesel")
}

model ConferenciaEstoque {
  id             String   @id @default(cuid())
  data           DateTime
  estoqueFisico  Float // informado pelo gerente
  estoqueTeorico Float // entradas - abastecimentos
  diferenca      Float? // calculado automaticamente
  percentualDif  Float? // (diferenca / estoqueTeorico) * 100
  alerta         Boolean  @default(false)

  custoMedioLitro   Float? // média ponderada
  custoTotalConsumo Float? // no período

  observacao     String?
  realizadoPor   User    @relation(fields: [realizadoPorId], references: [id])
  realizadoPorId String

  dataCriacao DateTime @default(now())

  @@index([data])
  @@map("conferencias_estoque")
}

model RelatorioM2 {
  id          String   @id @default(cuid())
  dataPeriodo DateTime
  dataFim     DateTime

  estoqueTeorico Float
  estoqueFisico  Float
  diferenca      Float

  custoMedioHora    Float // custo total / horas trabalhadas
  custoMedioLitro   Float
  custoTotalConsumo Float

  dataCriacao DateTime @default(now())

  @@map("relatorios_m2")
}

// ========== M3 - RECEITAS E INSUMOS ==========

enum SequenciaAplicacao {
  PRIMEIRA
  SEGUNDA
  TERCEIRA
  QUARTA
  QUINTA
}

model ReceitaBase {
  id           String             @id @default(cuid())
  nome         String
  atividade    TipoAtividade
  sequencia    SequenciaAplicacao
  perfilTalhao PerfilTalhao
  safra        Safra              @relation("ReceitaBaseSafra", fields: [safraId], references: [id], onDelete: Cascade)
  safraId      String

  unidadeBase String // "bomba 1.000L" / "bag" / "tanque"

  // Produtos da receita
  produtosReceita ProdutoReceita[]

  // Ajustes
  ajustes AjusteReceita[]

  // Aplicações
  aplicacoes AplicacaoInsumo[]

  // SafraReceita relation
  safraReceita SafraReceita[] @relation("ReceitaBaseSafra")

  criadoPor   User   @relation("ReceitaBaseCriador", fields: [criadoPorId], references: [id])
  criadoPorId String

  dataCriacao       DateTime @default(now())
  ultimaAtualizacao DateTime @updatedAt

  @@unique([nome, safraId, perfilTalhao])
  @@map("receitas_base")
}

model ProdutoReceita {
  id        String      @id @default(cuid())
  receita   ReceitaBase @relation(fields: [receitaId], references: [id], onDelete: Cascade)
  receitaId String

  produto   Produto @relation("ProdutoReceitaBase", fields: [produtoId], references: [id])
  produtoId String

  doseUnidade Float // dose por unidade (bomba, bag, etc)

  @@unique([receitaId, produtoId])
  @@map("produtos_receita")
}

model AjusteReceita {
  id        String      @id @default(cuid())
  receita   ReceitaBase @relation(fields: [receitaId], references: [id], onDelete: Cascade)
  receitaId String

  tipo      String // "adicionar_produto" / "alterar_dose" / "remover_produto"
  produto   Produto? @relation("AjusteReceitaProduto", fields: [produtoId], references: [id], onDelete: SetNull)
  produtoId String?

  doseAnterior Float?
  doseNova     Float?

  realizadoPor   User   @relation(fields: [realizadoPorId], references: [id])
  realizadoPorId String

  dataCriacao DateTime @default(now())

  @@index([receitaId])
  @@map("ajustes_receita")
}

model AplicacaoInsumo {
  id        String      @id @default(cuid())
  receita   ReceitaBase @relation(fields: [receitaId], references: [id])
  receitaId String

  talhao   Talhao @relation(fields: [talhaoId], references: [id])
  talhaoId String

  registroAtividade   RegistroAtividade? @relation(fields: [registroAtividadeId], references: [id], onDelete: SetNull)
  registroAtividadeId String?

  safra   Safra  @relation("AplicacaoInsumoSafra", fields: [safraId], references: [id])
  safraId String

  data       DateTime
  quantidade Float // quantidade utilizada (bombas, bags, etc)

  // Cálculos
  quantidadeTotalPorProduto Float? // dose × quantidade
  custoPorProduto           Float? // quantidade × valor unitário
  custoTotal                Float? // soma dos custos
  custoPorHectare           Float? // custo total / área talhão
  produtividadeHaHora       Float? // quando horas informadas

  observacao     String?
  realizadoPor   User    @relation(fields: [realizadoPorId], references: [id])
  realizadoPorId String

  // SafraReceita relation
  safraReceita SafraReceita[] @relation("AplicacaoInsumoSafra")

  dataCriacao DateTime @default(now())

  @@index([talhaoId, data])
  @@map("aplicacoes_insumo")
}

model HistoricoAplicacao {
  id       String @id @default(cuid())
  talhao   Talhao @relation(fields: [talhaoId], references: [id])
  talhaoId String
  safra    Safra  @relation("HistoricoAplicacaoSafra", fields: [safraId], references: [id])
  safraId  String

  sequencia     Int // ordem da aplicação (1ª, 2ª, 3ª...)
  tipoAtividade TipoAtividade
  data          DateTime

  receita            String // snapshot do nome da receita
  perfilTalhaoNaData PerfilTalhao // imutável

  custoTotal      Float?
  custoPorHectare Float?

  // SafraReceita relation
  safraReceita SafraReceita[] @relation("HistoricoAplicacaoSafra")

  dataCriacao DateTime @default(now())

  @@index([talhaoId, safraId])
  @@map("historico_aplicacao")
}

// Extensão do modelo Safra para receitas
model SafraReceita {
  id      String @id @default(cuid())
  safra   Safra  @relation("SafraReceitasRelacao", fields: [safraId], references: [id], onDelete: Cascade)
  safraId String

  receitasBase ReceitaBase[]        @relation("ReceitaBaseSafra")
  aplicacoes   AplicacaoInsumo[]    @relation("AplicacaoInsumoSafra")
  historico    HistoricoAplicacao[] @relation("HistoricoAplicacaoSafra")

  // SafraExtended relation
  safraExtended SafraExtended?

  @@unique([safraId])
  @@map("safra_receitas")
}

// Extensão do modelo Safra
model SafraExtended {
  id      String @id @default(cuid())
  safra   Safra  @relation(fields: [safraId], references: [id], onDelete: Cascade)
  safraId String @unique

  receitaRelacao SafraReceita? @relation(fields: [safraReceitaId], references: [id], onDelete: SetNull)
  safraReceitaId String?       @unique

  @@map("safra_extended")
}

// ========== M4 - RASTREABILIDADE DO CAFÉ ==========

enum TipoColheita {
  MAQUINA
  MANUAL
  VARRICAO
}

enum TipoOperacaoLote {
  ORIGEM
  DIVISAO
  FUSAO
}

enum StatusLote {
  COLHEITA
  TERREIRO
  SECADOR
  TULHA
  BENEFICIO
  CLASSIFICACAO
  SILO
  ARMAZEM
  VENDIDO
}

// Modelo central: Lote de café
model Lote {
  id            String @id @default(cuid()) // ex: L2526-001
  identificador String @unique // ID amigável do lote
  safra         Safra  @relation(fields: [safraId], references: [id])
  safraId       String

  // Linhagem e operações
  tipoOperacao TipoOperacaoLote
  lotesOrigem  String[] // Array de IDs dos lotes que originaram este
  lotesDestino String[] // Array de lotes criados a partir deste

  // Status e medições
  statusAtual      StatusLote @default(COLHEITA)
  quantidadeTotal  Float // em litros
  quantidadeAltual Float? // atual (pode diminuir com processamento)

  // Rastreabilidade
  criadorId         String
  dataCriacao       DateTime @default(now())
  ultimaAtualizacao DateTime @updatedAt

  // Relacionamentos
  chegadas           ChegadaTerreiro[]
  etapaTerreiro      EtapaTerreiro?
  etapaSecador       EtapaSecador?
  etapaTulha         EtapaTulha?
  etapaBeneficio     EtapaBeneficio?
  etapaClassificacao EtapaClassificacao?
  etapaSilo          EtapaSilo?
  etapaArmazem       EtapaArmazem?

  // Fusões em Tulha
  fusoesTulhaComoPrincipal  FusaoTulha[] @relation("FusaoTulhaLotePrincipal")
  fusoesTulhaComoSecundario FusaoTulha[] @relation("FusaoTulhaLoteSecundario")

  // Fusões em Silo
  fusoesSiloComoPrincipal  FusaoSilo[] @relation("FusaoSiloLotePrincipal")
  fusoesSiloComoSecundario FusaoSilo[] @relation("FusaoSiloLoteSecundario")

  @@index([safraId])
  @@index([statusAtual])
  @@index([dataCriacao])
  @@map("lotes")
}

// Etapa 1: Colheita / Chegada no Terreiro
model ChegadaTerreiro {
  id     String  @id @default(cuid())
  lote   Lote?   @relation(fields: [loteId], references: [id], onDelete: Cascade)
  loteId String?

  safra   Safra  @relation(fields: [safraId], references: [id])
  safraId String

  talhao   Talhao @relation(fields: [talhaoId], references: [id])
  talhaoId String

  tipoColheita TipoColheita

  // Quantidade (pode vir em diferentes unidades)
  quantidade       Float
  unidadeOriginal  String // "carretas", "alqueires", "caminhões"
  quantidadeLitros Float // convertida automaticamente para litros

  observacao    String?
  responsavelId String
  dataCriacao   DateTime @default(now())

  @@index([loteId])
  @@index([safraId, talhaoId])
  @@index([dataCriacao])
  @@map("chegadas_terreiro")
}

// Etapa 2: Terreiro (Meia Seca)
model EtapaTerreiro {
  id     String @id @default(cuid())
  lote   Lote   @relation(fields: [loteId], references: [id], onDelete: Cascade)
  loteId String @unique

  umidadeEntrada Float // %
  umidadeSaida   Float? // %
  dataEntrada    DateTime
  dataSaida      DateTime?
  diasTerreiro   Int? // calculado

  observacao    String?
  responsavel   User     @relation(fields: [responsavelId], references: [id])
  responsavelId String
  dataCriacao   DateTime @default(now())

  @@map("etapas_terreiro")
}

// Etapa 3: Secador Estático
model EtapaSecador {
  id     String @id @default(cuid())
  lote   Lote   @relation(fields: [loteId], references: [id], onDelete: Cascade)
  loteId String @unique

  secadorId        Int // 1, 2, 3, ... (38.000 L cada)
  quantidadeLitros Float
  dataEntrada      DateTime
  horaEntrada      String? // HH:MM
  dataSaida        DateTime?
  horaSaida        String? // HH:MM

  umidadeInicial Float
  umidadeSaida   Float?
  tempoSecagem   Float? // em horas, calculado

  observacao    String?
  responsavel   User     @relation(fields: [responsavelId], references: [id])
  responsavelId String
  dataCriacao   DateTime @default(now())

  @@map("etapas_secador")
}

// Etapa 4: Tulha de Descanso
model EtapaTulha {
  id     String @id @default(cuid())
  lote   Lote   @relation(fields: [loteId], references: [id], onDelete: Cascade)
  loteId String @unique

  tulhaId          Int // 1-6 (76.000 L cada, comporta 2 secadores)
  quantidadeLitros Float
  dataEntrada      DateTime
  dataSaida        DateTime?

  // Histórico de fusões nesta tulha
  fusoesTulha FusaoTulha[]

  observacao    String?
  responsavel   User     @relation(fields: [responsavelId], references: [id])
  responsavelId String
  dataCriacao   DateTime @default(now())

  @@map("etapas_tulha")
}

// Registro de Fusão em Tulha
model FusaoTulha {
  id      String     @id @default(cuid())
  tulha   EtapaTulha @relation(fields: [tulhaId], references: [id], onDelete: Cascade)
  tulhaId String

  lotePrincipal    Lote   @relation("FusaoTulhaLotePrincipal", fields: [lotePrincipalId], references: [id])
  lotePrincipalId  String
  loteSecundario   Lote   @relation("FusaoTulhaLoteSecundario", fields: [loteSecundarioId], references: [id])
  loteSecundarioId String

  quantidadeTotal Float
  dataFusao       DateTime
  realizadoPor    String?
  observacao      String?

  @@index([tulhaId])
  @@map("fusoes_tulha")
}

// Etapa 5a: Benefício (Operacional)
model EtapaBeneficio {
  id     String @id @default(cuid())
  lote   Lote   @relation(fields: [loteId], references: [id], onDelete: Cascade)
  loteId String @unique

  horaInicio         String // HH:MM
  horaFim            String? // HH:MM
  tempoProcessamento Float? // calculado em horas

  umidadeEntrada Float
  umidadeSaida   Float?
  observacao     String?

  responsavel   User     @relation(fields: [responsavelId], references: [id])
  responsavelId String
  dataCriacao   DateTime @default(now())

  @@map("etapas_beneficio")
}

// Etapa 5b: Classificação Física
model EtapaClassificacao {
  id     String @id @default(cuid())
  lote   Lote   @relation(fields: [loteId], references: [id], onDelete: Cascade)
  loteId String @unique

  peneira17Plus Float // %
  peneira16     Float // %
  peneira15     Float // %
  moca10        Float // %
  peneira13     Float // %
  catacao       Float // %
  fundo         Float? // %

  pontuacaoBebida Float? // 0-100
  umidadeFinal    Float

  observacao        String?
  responsavel       User     @relation(fields: [responsavelId], references: [id])
  responsavelId     String
  dataClassificacao DateTime @default(now())

  @@map("etapas_classificacao")
}

// Etapa 6: Silos
model EtapaSilo {
  id     String @id @default(cuid())
  lote   Lote   @relation(fields: [loteId], references: [id], onDelete: Cascade)
  loteId String @unique

  siloId      Int // ID do silo (1, 2, 3, etc)
  dataEntrada DateTime
  dataSaida   DateTime?

  fusoesSilo FusaoSilo[]

  observacao    String?
  responsavel   User     @relation(fields: [responsavelId], references: [id])
  responsavelId String
  dataCriacao   DateTime @default(now())

  @@map("etapas_silo")
}

// Registro de Fusão em Silo
model FusaoSilo {
  id     String    @id @default(cuid())
  silo   EtapaSilo @relation(fields: [siloId], references: [id], onDelete: Cascade)
  siloId String

  lotePrincipal    Lote   @relation("FusaoSiloLotePrincipal", fields: [lotePrincipalId], references: [id])
  lotePrincipalId  String
  loteSecundario   Lote   @relation("FusaoSiloLoteSecundario", fields: [loteSecundarioId], references: [id])
  loteSecundarioId String

  quantidadeTotal Float
  dataFusao       DateTime
  realizadoPor    String?
  observacao      String?

  @@map("fusoes_silo")
}

// Etapa 7: Armazém
model EtapaArmazem {
  id     String @id @default(cuid())
  lote   Lote   @relation(fields: [loteId], references: [id], onDelete: Cascade)
  loteId String @unique

  dataSaida         DateTime?
  pesoKg            Float?
  quantidadeSacas   Int?
  nfTransporte      String?
  armazemDestino    String?
  numerosPesagem    String?
  pesoBruto         Float? // em kg
  pesoLiquido       Float? // em kg (após limpeza)
  numeroLoteArmazem String? // ID do lote no armazém

  nomeArmazem   String?
  numeroBalanca String?

  observacao    String?
  responsavel   User     @relation(fields: [responsavelId], references: [id])
  responsavelId String
  dataCriacao   DateTime @default(now())

  @@map("etapas_armazem")
}

// Divisão de Lote
model DivisaoLote {
  id           String   @id @default(cuid())
  loteOriginal String // ID do lote original
  lotesDestino String[] // IDs dos lotes criados (ex: L001-A, L001-B)

  motivo     String? // ex: "Excede capacidade secador"
  observacao String?

  realizadoPor String
  dataCriacao  DateTime @default(now())

  @@index([loteOriginal])
  @@map("divisoes_lote")
}

// M5 - Painel do Gestor

// Vale (Adiantamento)
model Vale {
  id        String @id @default(cuid())
  usuario   User   @relation("ValesRecebidos", fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String

  valor          Float // R$
  dataLancamento DateTime
  mesPagamento   String // ex: "2025-06" (ano-mês para controle)

  motivo    String? // opcional: motivo do vale
  descricao String? // descrição adicional

  lancadoPor   User   @relation("ValesLancados", fields: [lancadoPorId], references: [id])
  lancadoPorId String

  status           String    @default("PENDENTE") // PENDENTE, DESCONTADO, CANCELADO
  dataCancelamento DateTime?

  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  @@index([usuarioId])
  @@index([mesPagamento])
  @@map("vales")
}

// M7 - Assistente de IA

// Sessão de Chat com IA
model AssistantChat {
  id        String @id @default(cuid())
  usuario   User   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String

  titulo    String? // título da conversa
  mensagens ChatMessage[]

  ativa       Boolean   @default(true)
  dataCriacao DateTime  @default(now())
  dataFinal   DateTime?

  @@index([usuarioId])
  @@map("assistant_chats")
}

// Mensagem individual no chat
model ChatMessage {
  id     String        @id @default(cuid())
  chat   AssistantChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String

  papel    String // "usuario" ou "assistant"
  conteudo String @db.Text

  dataCriacao DateTime @default(now())

  @@index([chatId])
  @@map("chat_messages")
}

// Log de Alterações Solicitadas via IA
model AssistantLog {
  id        String @id @default(cuid())
  usuario   User   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String

  tipoAlteracao        String // "campo", "regra", "relatorio", "permissao", etc
  descricaoSolicitacao String @db.Text

  previa String? @db.Text // JSON com prévia da alteração
  status String  @default("PENDENTE") // PENDENTE, APROVADO, REJEITADO, APLICADO

  dataAprovacao  DateTime?
  dataaplicacao  DateTime?
  motivoRejeicao String?

  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  @@index([usuarioId])
  @@index([status])
  @@map("assistant_logs")
}
model TipoAtividadeCadastro {
  id          Int       @id @default(autoincrement())
  nome        String    @unique
  descricao   String?
  ativo       Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("tipos_atividade")
}